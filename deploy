#==============================================================================#
# MAIN
#==============================================================================#

main() {
    case "${1:-}" in
        setup)       do_setup ;;
        install)     do_install ;;
        supabase)    do_supabase ;;
        harden)      do_harden ;;
        flutter)     do_flutter ;;
        gate)        run_health_gate ;;
        pgdog)       do_pgdog ;;
        status)      do_status ;;
        sync-schema) do_sync_schema "${2:-}" ;;
        help|-h|--help) show_help ;;
        "")          do_all ;;
        *)
            log_error "Unknown command: $1"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
