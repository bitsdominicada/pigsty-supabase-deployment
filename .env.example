#==============================================================================#
# PIGSTY SUPABASE - Configuration Example
#==============================================================================#
# Copy this to .env and fill in your values, or run: ./deploy setup
#==============================================================================#

# VPS Connection
VPS_HOST=your-vps-ip
SSH_USER=ubuntu
SSH_KEY=~/.ssh/id_ed25519
SSH_KEY_PATH=~/.ssh/id_ed25519

# Domain
CLIENT_NAME=clientname
BASE_DOMAIN=yourdomain.com
SUPABASE_DOMAIN=clientname.yourdomain.com
DNS_MODE=platform
APP_DOMAIN=app.yourdomain.com
POS_DOMAIN=pos.yourdomain.com
AI_DOMAIN=ai.yourdomain.com
API_DOMAIN=api.yourdomain.com
STUDIO_DOMAIN=studio.yourdomain.com
GRAFANA_DOMAIN=grafana.yourdomain.com
PROM_DOMAIN=prom.yourdomain.com

# SSL (Let's Encrypt)
USE_LETSENCRYPT=true
LETSENCRYPT_EMAIL=admin@yourdomain.com

# Cloudflare DNS (optional but recommended for auto DNS)
CF_API_TOKEN=
CF_ZONE_ID=
CF_PROXIED=true
CF_TTL=300

# PostgreSQL (auto-generated by ./deploy setup)
POSTGRES_PASSWORD=
PG_ADMIN_PASSWORD=
PG_MONITOR_PASSWORD=
PG_REPLICATION_PASSWORD=
PATRONI_PASSWORD=

# Supabase JWT (auto-generated by ./deploy setup)
JWT_SECRET=
ANON_KEY=
SERVICE_ROLE_KEY=

# Supabase Dashboard
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=

# Supabase Internal
PG_META_CRYPTO_KEY=
SECRET_KEY_BASE=
LOGFLARE_API_KEY=

# Monitoring
GRAFANA_ADMIN_PASSWORD=
HEALTH_GATE_ATTEMPTS=18
HEALTH_GATE_SLEEP_SECONDS=10

# Storage (Backblaze B2) - Optional
STORAGE_BACKEND=minio
S3_BUCKET=
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_REGION=us-east-005
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_RELAY_IP=

# Backups
PGBACKREST_CIPHER_PASS=

# SMTP - Optional
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER_NAME=
SMTP_ADMIN_EMAIL=
ALERT_EMAIL_TO=
