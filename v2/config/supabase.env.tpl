#==============================================================#
# Supabase Docker .env (generated by pigsty-v2)
# Template: v2/config/supabase.env.tpl
#==============================================================#

############
# Secrets
############
POSTGRES_PASSWORD=${SUPABASE_DB_PASSWORD}
JWT_SECRET=${JWT_SECRET}
ANON_KEY=${ANON_KEY}
SERVICE_ROLE_KEY=${SERVICE_ROLE_KEY}
SECRET_KEY_BASE=${SECRET_KEY_BASE}
PG_META_CRYPTO_KEY=${PG_META_CRYPTO_KEY}

DASHBOARD_USERNAME=${DASHBOARD_USERNAME}
DASHBOARD_PASSWORD=${DASHBOARD_PASSWORD}

############
# Database
############
POSTGRES_HOST=${META_PRIVATE_IP}
POSTGRES_PORT=5436
POSTGRES_DB=postgres
POSTGRES_DOMAIN=${PG_CLUSTER_NAME}

############
# Domain
############
SUPABASE_PUBLIC_URL=https://${APP_FQDN}
API_EXTERNAL_URL=https://${API_FQDN}
SITE_URL=https://${APP_FQDN}

############
# API Proxy
############
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

############
# PostgREST
############
PGRST_DB_SCHEMAS=public,storage,graphql_public

############
# Auth
############
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true

SMTP_ADMIN_EMAIL=${SMTP_ADMIN_EMAIL}
SMTP_HOST=${SMTP_HOST}
SMTP_PORT=${SMTP_PORT}
SMTP_USER=${SMTP_USER}
SMTP_PASS=${SMTP_PASS}
SMTP_SENDER_NAME=${SMTP_SENDER_NAME}
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

############
# Studio
############
STUDIO_PORT=3000
STUDIO_DEFAULT_PROJECT=Pigsty
STUDIO_DEFAULT_ORGANIZATION=Pigsty

IMGPROXY_ENABLE_WEBP_DETECTION=true
OPENAI_API_KEY=

############
# Storage (Backblaze B2)
############
S3_BUCKET=${S3_BUCKET}
S3_ENDPOINT=${S3_ENDPOINT}
S3_ACCESS_KEY=${S3_ACCESS_KEY}
S3_SECRET_KEY=${S3_SECRET_KEY}
S3_FORCE_PATH_STYLE=true
S3_PROTOCOL=https
S3_REGION=${S3_REGION}
S3_PROTOCOL_ACCESS_KEY_ID=${S3_ACCESS_KEY}
S3_PROTOCOL_ACCESS_KEY_SECRET=${S3_SECRET_KEY}
MINIO_DOMAIN_IP=127.0.0.1

############
# Realtime
############
SECRET_KEY_BASE=${SECRET_KEY_BASE}

############
# Functions
############
FUNCTIONS_VERIFY_JWT=false

############
# Analytics / Logflare
############
LOGFLARE_PUBLIC_ACCESS_TOKEN=${LOGFLARE_PUBLIC_ACCESS_TOKEN}
LOGFLARE_PRIVATE_ACCESS_TOKEN=${LOGFLARE_PRIVATE_ACCESS_TOKEN}
LOGFLARE_LOG_LEVEL=error

DOCKER_SOCKET_LOCATION=/var/run/docker.sock
TUS_ALLOW_S3_TAGS=false
