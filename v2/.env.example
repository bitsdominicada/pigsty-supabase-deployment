# V2 local credentials (do not commit real secrets)
# Copy to v2/.env and fill only what you need.

# --- Provider API tokens ---
VULTR_API_KEY=
HCLOUD_TOKEN=
DIGITALOCEAN_TOKEN=
LINODE_TOKEN=

# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Azure
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=

# GCP
GOOGLE_APPLICATION_CREDENTIALS=

# --- Optional Terraform input variables ---
# Example for Vultr:
# TF_VAR_region=lax
# TF_VAR_distro=d12

