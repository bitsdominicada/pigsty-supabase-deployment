# =============================================================
# Pigsty Supabase V2 — Environment Contract
# =============================================================
# Copy to v2/.env and fill every REQUIRED variable.
# The deploy pipeline will refuse to run if any REQUIRED value
# is empty.  Optional values have sensible defaults.
# =============================================================

# -----------------------------------------------------------
# PROVIDER API TOKENS (only the one you use is required)
# -----------------------------------------------------------
VULTR_API_KEY=
HCLOUD_TOKEN=
DIGITALOCEAN_TOKEN=
LINODE_TOKEN=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=
ARM_CLIENT_ID=
ARM_CLIENT_SECRET=
ARM_SUBSCRIPTION_ID=
ARM_TENANT_ID=
GOOGLE_APPLICATION_CREDENTIALS=

# -----------------------------------------------------------
# TERRAFORM INPUT VARIABLES (optional overrides)
# -----------------------------------------------------------
# TF_VAR_region=mia
# TF_VAR_distro=d12

# -----------------------------------------------------------
# CLUSTER IDENTITY  (REQUIRED)
# -----------------------------------------------------------
# Public IP of pg-meta node (reserved IP after terraform apply)
META_IP=
# Private IPs assigned by VPC (from terraform output)
META_PRIVATE_IP=10.10.10.3
DB1_PRIVATE_IP=10.10.10.4
DB2_PRIVATE_IP=10.10.10.5

# SSH user for remote commands (default: root)
SSH_USER=root

# Optional local source for Supabase Edge Functions deploy helper
# Example:
# SUPABASE_FUNCTIONS_SOURCE=/Users/you/Projects/bits_flare_platform/supabase/functions
SUPABASE_FUNCTIONS_SOURCE=

# Optional local source for incremental app SQL migrations
# Example:
# SUPABASE_MIGRATIONS_SOURCE=/Users/you/Projects/bits_flare_platform/deployment/migrations
SUPABASE_MIGRATIONS_SOURCE=

# -----------------------------------------------------------
# PIGSTY  (REQUIRED)
# -----------------------------------------------------------
PIGSTY_VERSION=v4.2.0
PG_VERSION=18
PG_CLUSTER_NAME=pg-meta

# Supabase DB password — shared across supabase_admin,
# authenticator, and all supabase_*_admin users.
# Generate with: openssl rand -base64 30
SUPABASE_DB_PASSWORD=

# -----------------------------------------------------------
# SUPABASE SECRETS  (REQUIRED)
# -----------------------------------------------------------
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Generate ANON_KEY & SERVICE_ROLE_KEY from JWT_SECRET:
#   https://supabase.com/docs/guides/self-hosting/docker#api-keys
ANON_KEY=
SERVICE_ROLE_KEY=

# Random 32-64 char strings
PG_META_CRYPTO_KEY=
SECRET_KEY_BASE=

# Studio credentials
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=

# -----------------------------------------------------------
# DOMAIN / SSL  (REQUIRED)
# -----------------------------------------------------------
DOMAIN=bitsneura.com
APP_SUBDOMAIN=app
API_SUBDOMAIN=api
STUDIO_SUBDOMAIN=studio
POS_SUBDOMAIN=pos
AI_SUBDOMAIN=ai
PORTAL_SUBDOMAIN=home
REGISTRY_SUBDOMAIN=registry
REGISTRY_UI_SUBDOMAIN=registry-ui

# Cloudflare
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=

# Certbot
CERTBOT_EMAIL=

# -----------------------------------------------------------
# BACKBLAZE B2 / S3 STORAGE  (REQUIRED for backups + storage)
# -----------------------------------------------------------
S3_BUCKET=
S3_ENDPOINT=https://s3.us-east-005.backblazeb2.com
S3_REGION=us-east-005
S3_ACCESS_KEY=
S3_SECRET_KEY=

# pgBackRest
PGBACKREST_S3_BUCKET=
PGBACKREST_S3_PATH=/pgbackrest-b2
PGBACKREST_CIPHER_PASS=

# -----------------------------------------------------------
# SMTP  (optional — email auth requires it)
# -----------------------------------------------------------
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
SMTP_SENDER_NAME=Bits
SMTP_ADMIN_EMAIL=noreply@updates.bits.do

# -----------------------------------------------------------
# MONITORING PASSWORDS  (optional — defaults shown)
# -----------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=pigsty
PG_ADMIN_PASSWORD=DBUser.DBA
PG_MONITOR_PASSWORD=DBUser.Monitor
PG_REPLICATION_PASSWORD=DBUser.Replicator
PATRONI_PASSWORD=Patroni.API
HAPROXY_ADMIN_PASSWORD=pigsty
ETCD_ROOT_PASSWORD=Etcd.Root

# -----------------------------------------------------------
# LOGFLARE (optional)
# -----------------------------------------------------------
LOGFLARE_PUBLIC_ACCESS_TOKEN=1234567890abcdef1234567890abcdef
LOGFLARE_PRIVATE_ACCESS_TOKEN=fedcba0987654321fedcba0987654321
